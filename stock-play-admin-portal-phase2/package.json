{
  "name": "stock-play-admin",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "iconoir-react": "^7.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:backend": "cd backend-node && npm run dev",
    "start:api": "cd server && uvicorn app.main:app --reload",
    "seed:api": "cd server && python -m app.seed",
    "seed:api:reset": "cd server && python -m app.seed --reset",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
