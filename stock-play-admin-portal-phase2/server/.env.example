MONGODB_URI=mongodb://localhost:27017
DB_NAME=stock_play_admin

# Expiry job scheduler
ENABLE_EXPIRY_CRON=true
EXPIRY_CRON_HOUR=0
EXPIRY_CRON_MINUTE=30
EXPIRY_CRON_TIMEZONE=UTC
# Set >0 to use interval mode instead of daily cron
EXPIRY_CRON_INTERVAL_MINUTES=0
RUN_EXPIRY_JOB_ON_STARTUP=true

# Resend (for expiry notices and reset email)
RESEND_API_KEY=
RESEND_FROM=

# Legacy SMTP (unused if Resend is configured)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=
# SENDER_PASSWORD=
